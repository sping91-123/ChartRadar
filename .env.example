NEXT_PUBLIC_SITE_URL=https://your-domain.kr

# Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Google OAuth web client ID for web GIS and Android native Google Sign-In.
# Android also needs a separate Google Cloud Android OAuth client with package name and SHA-1.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Kakao REST API key for direct Kakao authorization code login.
NEXT_PUBLIC_KAKAO_REST_API_KEY=
# Optional. Leave empty unless Kakao consent items are enabled.
NEXT_PUBLIC_KAKAO_AUTH_SCOPE=
# Server-only. Required when Kakao REST API client secret is enabled.
KAKAO_CLIENT_SECRET=
# Server-only. Never expose this value to browser code.
SUPABASE_SERVICE_ROLE_KEY=
# Store the refresh token so login and Pro entitlement survive app restarts.
# Set false only after replacing this with cookie or secure-storage session persistence.
NEXT_PUBLIC_ALLOW_LOCAL_REFRESH_TOKEN=true

# Optional. Web checkout links by product.
NEXT_PUBLIC_PRO_PAYMENT_URL=
NEXT_PUBLIC_PRO_MONTHLY_PAYMENT_URL=
NEXT_PUBLIC_PRO_YEARLY_PAYMENT_URL=
NEXT_PUBLIC_CRYPTO_MONTHLY_PAYMENT_URL=
NEXT_PUBLIC_CRYPTO_YEARLY_PAYMENT_URL=
NEXT_PUBLIC_GLOBAL_MONTHLY_PAYMENT_URL=
NEXT_PUBLIC_GLOBAL_YEARLY_PAYMENT_URL=
NEXT_PUBLIC_STOCKS_MONTHLY_PAYMENT_URL=
NEXT_PUBLIC_STOCKS_YEARLY_PAYMENT_URL=
NEXT_PUBLIC_BUNDLE_MONTHLY_PAYMENT_URL=
NEXT_PUBLIC_BUNDLE_YEARLY_PAYMENT_URL=

# Optional. TossPayments direct checkout keys.
# Keep the secret key server-side only.
NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=
TOSS_PAYMENTS_SECRET_KEY=

NEXT_PUBLIC_REVENUECAT_ANDROID_API_KEY=
NEXT_PUBLIC_REVENUECAT_IOS_API_KEY=
REVENUECAT_REST_API_KEY=

# Optional. AI providers. Groq is the default production provider.
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b
GEMINI_API_KEY=
# Optional. Keep false/empty unless you intentionally accept Gemini API costs after Groq fails.
ENABLE_GEMINI_AI_FALLBACK=
# Optional. Keep empty for faster local title cleanup. Set to mymemory only if you accept slower free translation calls.
NEWS_TRANSLATION_PROVIDER=
# Optional. Groq is preferred. Set true only when Gemini should be tried after Groq fails.
ENABLE_GEMINI_NEWS_FALLBACK=

# Optional. Production API rate limit storage.
# Local development falls back to memory when these are empty.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional. Mobile shell target URL.
CAPACITOR_SERVER_URL=https://your-domain.kr

# Server-only. Required for Vercel Cron protected automatic Android app push.
CRON_SECRET=
# Server-only. Firebase Cloud Messaging HTTP v1 credentials for Android app push.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
