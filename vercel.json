{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "src/app/api/crypto-home-snapshot/route.ts": {
      "regions": ["icn1"]
    },
    "src/app/api/crypto-home-ticker/route.ts": {
      "regions": ["icn1"]
    },
    "src/app/api/liquidation-pressure/route.ts": {
      "regions": ["icn1"]
    },
    "src/app/api/large-trade-flow/route.ts": {
      "regions": ["icn1"]
    },
    "src/app/api/crypto/perpetual/snapshot/route.ts": {
      "regions": ["sin1"]
    },
    "src/app/api/crypto/perpetual/monitors/route.ts": {
      "regions": ["sin1"]
    },
    "src/app/api/push-cron/route.ts": {
      "regions": ["sin1"]
    },
    "src/app/api/macro-sync/route.ts": {
      "regions": ["icn1"]
    }
  },
  "crons": [
    {
      "path": "/api/push-cron",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/macro-sync",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/account-deletions/process",
      "schedule": "17 * * * *"
    }
  ]
}
